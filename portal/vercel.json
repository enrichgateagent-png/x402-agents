{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "/api/sitemap"
    },
    {
      "source": "/robots.txt",
      "destination": "/api/robots"
    },
    {
      "source": "/discover/:path*",
      "destination": "https://registry-ruby.vercel.app/discover/:path*"
    },
    {
      "source": "/llms.txt",
      "destination": "https://registry-ruby.vercel.app/llms.txt"
    },
    {
      "source": "/.well-known/ai-plugin.json",
      "destination": "https://registry-ruby.vercel.app/.well-known/ai-plugin.json"
    },
    {
      "source": "/beacon.cursorrules",
      "destination": "https://registry-ruby.vercel.app/beacon.cursorrules"
    },
    {
      "source": "/api/admin/:path*",
      "destination": "https://registry-ruby.vercel.app/api/admin/:path*"
    },
    {
      "source": "/api/v1/:path*",
      "destination": "https://registry-ruby.vercel.app/api/v1/:path*"
    },
    {
      "source": "/healthz",
      "destination": "https://registry-ruby.vercel.app/healthz"
    }
  ]
}
