# Beacon Registry — environment variables
# Copy to registry/.env and fill in values.

# Local SQLite database file (absolute path on the VM)
SQLITE_DB_PATH=/home/gcp_user/beacon_prod.db

# FastAPI listen port
PORT=8000

# Public URL (used in badges, llms.txt, ai-plugin.json)
PUBLIC_BASE_URL=http://YOUR_GCP_VM_IP:8000

PORTAL_URL=https://portal-five-phi-54.vercel.app

# GitHub PAT for enrich_github.py (optional but recommended)
GITHUB_TOKEN=

# MCP SSE server (Glama remote proxy)
BEACON_REGISTRY_URL=http://127.0.0.1:8000
MCP_SSE_PORT=8001

# Registry tuning
VALIDATION_TIMEOUT=6
REGISTRY_ONLINE_WINDOW=300
REGISTRY_MAX_RESULTS=25
ACTIVE_WINDOW_DAYS=90
