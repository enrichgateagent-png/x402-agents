{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.enrichgateagent-png/beacon-mcp",
  "description": "Search 33,000+ open-source AI agents and MCP servers by capability. Tools: find_agent, top_agents, agent_details. One-command setup: npx beacon-mcp init. Free, no API key.",
  "repository": {
    "url": "https://github.com/enrichgateagent-png/x402-agents",
    "source": "github",
    "subfolder": "mcp/beacon-mcp"
  },
  "version": "0.1.4",
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://beacon-mcp-taupe.vercel.app/mcp"
    }
  ],
  "packages": [
    {
      "registryType": "npm",
      "identifier": "beacon-mcp",
      "version": "0.1.3",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "description": "Override Beacon registry URL (default https://registry-ruby.vercel.app)",
          "isRequired": false,
          "format": "string",
          "isSecret": false,
          "name": "BEACON_REGISTRY_URL"
        }
      ]
    }
  ]
}
