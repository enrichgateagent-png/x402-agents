# Wallet that receives USDC payments. Leave unset for free mode (local testing).
PAY_TO=

# base-sepolia (testnet) or base (mainnet, CDP facilitator recommended)
NETWORK=base-sepolia

PORT=4022

# ---- Upstream provider keys (enable routes by setting keys) ----
# Serper.dev — Google search results. ~$0.001/query upstream, we sell $0.01
SERPER_API_KEY=

# Firecrawl — scrape any URL to clean markdown. ~$0.003/page upstream, we sell $0.015
FIRECRAWL_API_KEY=

# Exa — neural/semantic web search. We sell $0.012
EXA_API_KEY=
